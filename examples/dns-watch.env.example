# Example notification config for dns-watch.sh.
# Copy to /etc/dns-watch/dns-watch.env and edit for your host.
# Do NOT commit the real env file.

GOTIFY_URL="https://gotify.example.invalid"
GOTIFY_TOKEN="replace-with-token"

MAIL_FROM="dns-watch <monitor@example.invalid>"
MAIL_TO="you@example.invalid"
MSMTP_BIN="/usr/bin/msmtp"
